@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Context.puml

' Modern flat styling: no shadows, sharper corners, clean sans-serif, modern palette.
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person",     $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("system",     $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")
UpdateElementStyle("external_system", $fontColor="#FFFFFF", $bgColor="#64748B", $borderColor="#334155")

title System Context — spring-on-k8s

Person(user, "End User", "Consumes the REST API over HTTPS")
System(sys, "spring-on-k8s", "Spring Boot 4.1 service: REST API + Actuator probes + Prometheus metrics + Swagger UI")
System_Ext(prom, "Prometheus", "Scrapes /actuator/prometheus")
System_Ext(k8s, "Kubernetes", "Runs the pod; probes liveness + readiness")

Rel(user, sys, "Uses", "HTTPS / JSON")
Rel(prom, sys, "Scrapes metrics", "HTTP")
Rel(k8s, sys, "Probes liveness + readiness", "HTTP")

SHOW_LEGEND()
@enduml
